{
    // Builtin
    "editor.cursorStyle": "block",
    "editor.fontFamily": "'JetBrainsMono Nerd Font', 'VictorMono Nerd Font', Consolas, Monaco, Menlo, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 15,
    "editor.fontWeight": "normal",
    "editor.guides.bracketPairs": true,
    "editor.guides.bracketPairsHorizontal": true,
    "editor.guides.highlightActiveIndentation": true,
    "editor.lineHeight": 1.5,
    "editor.lineNumbers": "relative",
    "editor.quickSuggestions": {
        "other": "on",
        "comments": "on",
        "strings": "on"
    },
    "editor.renderWhitespace": "all",
    "editor.rulers": [
        80
    ],
    "editor.tabSize": 2,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "comment",
                    "punctuation.definition.comment"
                ],
                "settings": {
                    "fontStyle": "italic bold"
                }
            },
        ]
    },
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "editor.semanticHighlighting.enabled": true,
    "files.autoSave": "afterDelay",
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.DS_Store": true,
        "**/*.{jpg, jpeg, png, gif, webp}": true,
    },
    "search.showLineNumbers": true,
    "search.smartCase": true,
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true
    },
    "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', 'VictorMono Nerd Font', Consolas, Monaco, Menlo, 'Courier New', monospace",
    "terminal.integrated.fontSize": 15,
    "terminal.integrated.gpuAcceleration": "on",
    "terminal.integrated.rightClickBehavior": "copyPaste",
    "terminal.integrated.minimumContrastRatio": 1.0,
    "window.titleBarStyle": "custom",
    "window.zoomLevel": -0.8,
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.colorCustomizations": {},
    "workbench.iconTheme": "vs-seti",
    "workbench.statusBar.visible": true,
    "workbench.startupEditor": "none",
    // PLUGIN: vim
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    },
    "vim.autoindent": true,
    "vim.camelCaseMotion.enable": true,
    "vim.cursorStylePerMode.insert": "line",
    "vim.cursorStylePerMode.normal": "block",
    "vim.cursorStylePerMode.replace": "block-outline",
    "vim.cursorStylePerMode.visual": "block-outline",
    "vim.cursorStylePerMode.visualblock": "block-outline",
    "vim.cursorStylePerMode.visualline": "block-outline",
    "vim.easymotion": true,
    "vim.handleKeys": {
        "<C-a>": false,
        "<C-f>": false
    },
    "vim.highlightedyank.enable": true,
    "vim.highlightedyank.duration": 2000,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "k"
            ],
            "after": [
                "<Esc>"
            ]
        }
    ],
    "vim.leader": "\\",
    "vim.ignorecase": true,
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<leader>",
                "<leader>",
                "<leader>"
            ],
            "commands": [
                "workbench.action.showCommands"
            ]
        },
        {
            "before": [
                "K"
            ],
            "commands": [
                "editor.action.showHover"
            ]
        },
        {
            "before": [
                "g",
                "d"
            ],
            "commands": [
                "editor.action.revealDefinition"
            ]
        },
        {
            "before": [
                "<leader>",
                "t",
                "a"
            ],
            "commands": [
                "workbench.action.toggleActivityBarVisibility"
            ]
        },
        {
            "before": [
                "<leader>",
                "t",
                "n"
            ],
            "commands": [
                "workbench.action.toggleSidebarVisibility"
            ]
        },
    ],
    "vim.showMarksInGutter": true,
    "vim.smartRelativeLine": true,
    "vim.sneak": true,
    "vim.sneakReplacesF": true,
    "vim.sneakUseIgnorecaseAndSmartcase": true,
    "vim.surround": true,
    "vim.showcmd": true,
    "vim.showmodename": true,
    "vim.useCtrlKeys": true,
    "vim.useSystemClipboard": true,
    "vim.visualstar": true,
    "vim.whichwrap": "b,s,h,l",
    // PLUGIN: catppuccin
    "catppuccin.accentColor": "blue",
    "catppuccin.colorOverrides": {
        "mocha": {
            "base": "#000000",
            "mantle": "#000000",
            "crust": "#000000",
        },
    },
    "catppuccin.customUIColors": {
        "mocha": {
            "editorLineNumber.activeForeground": "green",
        },
    },
    "catppuccin.italicComments": true,
    "catppuccin.italicKeywords": true,
    "catppuccin.boldKeywords": true,
    "catppuccin.workbenchMode": "flat",
    "catppuccin.bracketMode": "rainbow",
}
