{
    // Builtin
    "editor.cursorStyle": "block",
    "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Hack Nerd Font', Consolas, Monaco, Menlo, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.guides.bracketPairs": true,
    "editor.guides.bracketPairsHorizontal": true,
    "editor.guides.highlightActiveIndentation": true,
    "editor.lineHeight": 1.5,
    "editor.lineNumbers": "relative",
    "editor.quickSuggestions": {
        "other": "on",
        "comments": "off",
        "strings": "off"
    },
    "editor.renderWhitespace": "all",
    "editor.rulers": [
        80,
    ],
    "editor.tabSize": 2,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "comment",
                    "punctuation.definition.comment"
                ],
                "settings": {
                    "fontStyle": "bold"
                }
            },
        ]
    },
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "files.autoSave": "afterDelay",
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/*.{jpg, jpeg, png, gif, webp}": true,
        "**/Thumbs.db": true
    },
    "search.showLineNumbers": true,
    "search.smartCase": true,
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true
    },
    "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', 'Hack Nerd Font', Consolas, Monaco, Menlo, 'Courier New', monospace",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.gpuAcceleration": "on",
    "terminal.integrated.rightClickBehavior": "copyPaste",
    "window.titleBarStyle": "custom",
    "window.zoomLevel": -1.0,
    "workbench.colorTheme": "Default Dark Modern",
    "workbench.colorCustomizations": {
        "statusBar.background": "#225577",
        "statusBar.noFolderBackground": "#225577",
        "statusBar.debuggingBackground": "#225577",
        "statusBar.foreground": "#ffffff",
        "statusBar.debuggingForeground": "#ffffff"
    },
    "workbench.iconTheme": "vs-seti",
    "workbench.statusBar.visible": true,
    "workbench.startupEditor": "none",
    // PLUGIN: vim
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    },
    "vim.cursorStylePerMode.insert": "line",
    "vim.cursorStylePerMode.normal": "block",
    "vim.cursorStylePerMode.replace": "block-outline",
    "vim.cursorStylePerMode.visual": "block-outline",
    "vim.cursorStylePerMode.visualblock": "block-outline",
    "vim.cursorStylePerMode.visualline": "block-outline",
    "vim.easymotion": true,
    "vim.handleKeys": {
        "<C-a>": false,
        "<C-f>": false
    },
    "vim.highlightedyank.enable": true,
    "vim.highlightedyank.color": "#ff0000",
    "vim.highlightedyank.textColor": "#ffffff",
    "vim.highlightedyank.duration": 1500,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "k"
            ],
            "after": [
                "<Esc>"
            ]
        }
    ],
    "vim.leader": "\\", // localleader not support yet
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<leader>",
                "<leader>",
                "<leader>"
            ],
            "commands": [
                "workbench.action.showCommands"
            ]
        },
        {
            "before": [
                "K"
            ],
            "commands": [
                "editor.action.showHover"
            ]
        },
        {
            "before": [
                "g",
                "d"
            ],
            "commands": [
                "editor.action.revealDefinition"
            ]
        },
        {
            "before": [
                "<leader>",
                "t",
                "a"
            ],
            "commands": [
                "workbench.action.toggleActivityBarVisibility"
            ]
        },
        {
            "before": [
                "<leader>",
                "t",
                "n"
            ],
            "commands": [
                "workbench.action.toggleSidebarVisibility"
            ]
        },
        {
            "before": [
                "<leader>",
                "t",
                "m"
            ],
            "commands": [
                "editor.action.toggleMinimap"
            ]
        },
    ],
    "vim.showMarksInGutter": true,
    "vim.smartRelativeLine": true,
    "vim.sneak": true,
    "vim.sneakReplacesF": true,
    "vim.sneakUseIgnorecaseAndSmartcase": true,
    "vim.statusBarColorControl": true,
    "vim.statusBarColors.commandlineinprogress": [
        "#557722",
        "#ffffff"
    ],
    "vim.statusBarColors.insert": [
        "#ff0000",
        "#ffffff"
    ],
    "vim.statusBarColors.normal": [
        "#000000",
        "#ffffff"
    ],
    "vim.statusBarColors.replace": [
        "#227755",
        "#ffffff"
    ],
    "vim.statusBarColors.searchinprogressmode": [
        "#b16286",
        "#ebdbb2"
    ],
    "vim.statusBarColors.visual": [
        "#225577",
        "#ffffff"
    ],
    "vim.statusBarColors.visualblock": [
        "#225577",
        "#ffffff"
    ],
    "vim.statusBarColors.visualline": [
        "#225577",
        "#ffffff"
    ],
    "vim.useCtrlKeys": true,
    "vim.useSystemClipboard": true,
    "vim.visualstar": true,
}
