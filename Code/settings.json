{
    // [[ PATH ]]
    //    Linux => ~/.config/Code/User/
    //    MacOS => ~/Library/Application Support/Code/User/
    //    Windows => %AppData%\Code\User
    // [[ REFERENCE ]]
    //    https://github.com/mydearxym/vscode-backup
    //    https://zhuanlan.zhihu.com/p/73561114
    //    https://vspacecode.github.io/
    //    https://zhuanlan.zhihu.com/p/302568011
    //    https://github.com/VSCodeVim/Vim
    //    https://vspacecode.github.io/docs/default-keybindings#file
    // [[ BUILTIN ]]
    "editor.cursorStyle": "block",
    "editor.fontFamily": "Menlo, Monaco, 'JetBrainsMono Nerd Font', Consolas, 'Courier New', monospace",
    "editor.fontSize": 16,
    "editor.fontWeight": "600",
    "editor.guides.bracketPairs": true,
    "editor.guides.bracketPairsHorizontal": true,
    "editor.guides.highlightActiveIndentation": true,
    "editor.lineHeight": 1.618,
    "editor.lineNumbers": "relative",
    "editor.renderWhitespace": "all",
    "editor.minimap.enabled": false,
    "editor.semanticHighlighting.enabled": true,
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "hidden",
    "editor.rulers": [
        80
    ],
    "editor.tabSize": 2,
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/*.{jpg, jpeg, png, gif, webp}": true,
    },
    "search.showLineNumbers": true,
    "search.smartCase": true,
    "terminal.integrated.fontFamily": "Menlo, Monaco, 'JetBrainsMono Nerd Font', Consolas, 'Courier New', monospace",
    "terminal.integrated.fontSize": 16,
    "window.zoomLevel": -1.6,
    "workbench.startupEditor": "none",
    "workbench.activityBar.location": "top",
    "workbench.colorCustomizations": {
        "statusBar.background": "#557700",
        "statusBar.noFolderBackground": "#557700",
        "statusBar.debuggingBackground": "#557700",
        "statusBar.foreground": "#ffffff",
        "statusBar.debuggingForeground": "#ffffff"
    },
    // [[ PLUGIN: vim ]]
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    },
    "vim.autoindent": true,
    "vim.camelCaseMotion.enable": true,
    "vim.cursorStylePerMode.insert": "line",
    "vim.cursorStylePerMode.normal": "block",
    "vim.cursorStylePerMode.replace": "block-outline",
    "vim.cursorStylePerMode.visual": "block-outline",
    "vim.cursorStylePerMode.visualblock": "block-outline",
    "vim.cursorStylePerMode.visualline": "block-outline",
    "vim.easymotion": true,
    "vim.handleKeys": {
        "<C-d>": true,
        "<C-s>": false,
        "<C-z>": false
    },
    "vim.highlightedyank.enable": true,
    "vim.highlightedyank.duration": 3000,
    "vim.highlightedyank.color": "#ff0000",
    "vim.highlightedyank.textColor": "#ffffff",
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "k"
            ],
            "after": [
                "<Esc>"
            ]
        }
    ],
    "vim.leader": "\\",
    "vim.ignorecase": true,
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<leader>",
                "<leader>",
                "<leader>"
            ],
            "commands": [
                "workbench.action.showCommands"
            ]
        },
        {
            "before": [
                "K"
            ],
            "commands": [
                "editor.action.showHover"
            ]
        },
        {
            "before": [
                "g",
                "d"
            ],
            "commands": [
                "editor.action.revealDefinition"
            ]
        },
        {
            "before": [
                "<leader>",
                "t",
                "a"
            ],
            "commands": [
                "workbench.action.toggleActivityBarVisibility"
            ]
        },
        {
            "before": [
                "<leader>",
                "t",
                "n"
            ],
            "commands": [
                "workbench.action.toggleSidebarVisibility"
            ]
        },
    ],
    "vim.searchHighlightColor": "#ff0000",
    "vim.searchHighlightTextColor": "#ffffff",
    "vim.searchMatchColor": "#005577",
    "vim.searchMatchTextColor": "#ffffff",
    "vim.substitutionColor": "#557700",
    "vim.substitutionTextColor": "#ffffff",
    "vim.showMarksInGutter": true,
    "vim.smartRelativeLine": true,
    "vim.sneak": true,
    "vim.sneakReplacesF": true,
    "vim.sneakUseIgnorecaseAndSmartcase": true,
    "vim.surround": true,
    "vim.showcmd": true,
    "vim.showmodename": true,
    "vim.useCtrlKeys": true,
    "vim.useSystemClipboard": true,
    "vim.visualstar": true,
    "vim.whichwrap": "b,s,h,l",
    "vim.statusBarColorControl": true,
    "vim.statusBarColors.normal": [
        "#000000",
        "#ffffff"
    ],
    "vim.statusBarColors.insert": [
        "#ff0000",
        "#ffffff"
    ],
    "vim.statusBarColors.visual": [
        "#557700",
        "#ffffff"
    ],
    "vim.statusBarColors.visualline": [
        "#557700",
        "#ffffff"
    ],
    "vim.statusBarColors.visualblock": [
        "#557700",
        "#ffffff"
    ],
    "vim.statusBarColors.replace": [
        "#770055",
        "#ffffff"
    ],
    "vim.statusBarColors.commandlineinprogress": [
        "#005577",
        "#ffffff"
    ],
    "vim.statusBarColors.searchinprogressmode": [
        "#005577",
        "#ffffff"
    ],
    "vim.statusBarColors.easymotionmode": [
        "#772200",
        "#ffffff"
    ],
    "vim.statusBarColors.easymotioninputmode": [
        "#772200",
        "#ffffff"
    ],
    "vim.statusBarColors.surroundinputmode": [
        "#772200",
        "#ffffff"
    ],
}
