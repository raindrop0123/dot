" For idea
set ideajoin

" For vim
set showmode
set hlsearch
set incsearch
set number
set relativenumber
set cursorline
set colorcolumn=80
set nowrap
set smartcase
set ignorecase
set whichwrap=h,l,<,>,[,],~
set clipboard^=unnamed,unnamedplus
set timeout
set timeoutlen=5000

" Mapping
let mapleader="\\"
let maplocalleader=","
inoremap jk <Esc>
inoremap <C-a> <home>
inoremap <C-e> <end>
nnoremap H ^
nnoremap L $
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l
nnoremap <leader>tt :action Terminal.OpenInTerminal<CR>
nnoremap <leader>ff :action GotoFile<CR>
nnoremap <leader>fr :action RecentFiles<CR>
nnoremap <leader>dd :action Debug<CR>
nnoremap <leader>ds :action Stop<CR>
nnoremap <leader>db :action ToggleLineBreakpoint<CR>
nnoremap <leader>rx :action ChooseRunConfiguration<CR>
nnoremap <leader>rr :action Run<CR>
nnoremap <leader>rc :action IdeaVim.ReloadVimRc.reload<CR>

" PLUGIN: easymotion
set easymotion
let g:EasyMotion_do_mapping=0
nmap <leader><leader>w <Plug>(easymotion-w)
nmap <leader><leader>l <Plug>(easymotion-lineanywhere)

" PLUGIN: sneak
set sneak

" PLUGIN: NERDTree
set NERDTree
nnoremap <leader>tn :NERDTreeToggle<CR>

" PLUGIN: surround
set surround

" PLUGIN: multiple-cursors
set multiple-cursors

" PLUGIN: commentary
set commentary

" PLUGIN: ReplaceWithRegister
set ReplaceWithRegister

" PLUGIN: argtextobj
set argtextobj

" PLUGIN: exchange
set exchange

" PLUGIN: textobj-entire
set textobj-entire

" PLUGIN: highlightedyank
set highlightedyank
let g:highlightedyank_highlight_duration="1000"
let g:highlightedyank_highlight_color="rgba(160, 160, 160, 155)"

" PLUGIN: vim-paragraph-motion
set vim-paragraph-motion

" PLUGIN: textobj-indent
set textobj-indent

" PLUGIN: matchit
set matchit

" PLUGIN: quickscope
set quickscope

" PLUGIN: which-key
set which-key
let g:WhichKey_DefaultDelay=0
let g:WhichKey_ShowVimActions="true"
let g:WhichKey_Divider=" │ "
let g:WhichKey_FontFamily="monospace"
let g:WhichKey_FontSize=12
let g:WhichKey_KeyStyle="bold"
let g:WhichKey_KeyColor="#00ff00"
let g:WhichKey_PrefixStyle="bold"
let g:WhichKey_PrefixColor="#ff00ff"
let g:WhichKey_CommandStyle="bold"
let g:WhichKey_CommandColor="#ffff00"
