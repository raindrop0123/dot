        \'   вЎқвЎөвЎ•вЎҖв ‘в ів ҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв ҝв ӣвўүвЎ вЎІвЎ«вЎӘвЎӘвЎЈ   ',
        \'',
        \'',
        \ ]
augroup END

augroup Gruvbox
  autocmd!
  autocmd BufEnter,BufReadPost * call plug#load('gruvbox')
        \| autocmd! Gruvbox
        \| colorscheme gruvbox
augroup END

augroup LightLine
  autocmd!
  autocmd BufReadPost * call plug#load('lightline.vim')
        \| autocmd! LightLine
        \| let g:lightline={'colorscheme': 'apprentice'}
        \| call lightline#enable()
augroup END

augroup IndentLine
  autocmd!
  autocmd BufReadPost * call plug#load('indentLine')
        \| autocmd! IndentLine
        \| IndentLinesToggle
augroup END

augroup ContextVim
  autocmd!
  autocmd BufReadPost * call plug#load('context.vim')
        \| autocmd! ContextVim
        \| ContextEnable
augroup END

augroup VimBufTabLine
  autocmd!
  autocmd BufReadPost * call plug#load('vim-buftabline')
        \| autocmd! VimBufTabLine
augroup END

augroup VimMatchUp
  autocmd!
  autocmd BufReadPost * call plug#load('vim-matchup')
        \| autocmd! VimMatchUp
augroup END

augroup VimBetterWhitespace
  autocmd!
  autocmd BufReadPost * call plug#load('vim-better-whitespace')
        \| autocmd! VimBetterWhitespace
augroup END

augroup AutoPairs
  autocmd!
  autocmd InsertEnter * call plug#load('auto-pairs')
        \| autocmd! AutoPairs
        \| call autopairs#AutoPairsTryInit()
augroup END

augroup Rainbow
  autocmd!
  autocmd BufReadPost * call plug#load('rainbow')
        \| autocmd! Rainbow
        \| RainbowToggle
augroup END

augroup VimCommentary
  autocmd!
  autocmd BufReadPost * call plug#load('vim-commentary')
        \| autocmd! VimCommentary
augroup END

augroup VimGitGutter
  autocmd!
  autocmd BufReadPost * call plug#load('vim-gitgutter')
        \| autocmd! VimGitGutter
        \| GitGutterEnable
augroup END

augroup ALE
  autocmd!
  autocmd BufReadPost * call plug#load('ale')
        \| autocmd! ALE
augroup END

augroup VimDevIcons
  autocmd!
  autocmd BufReadPost * call plug#load('vim-devicons')
        \| autocmd! VimDevIcons
augroup END

augroup VimHighlightedYank
  autocmd!
  autocmd BufReadPost * call plug#load('vim-highlightedyank')
        \| autocmd! VimHighlightedYank
        \| let g:highlightedyank_highlight_duration=2500
augroup END

augroup Terminus
  autocmd!
  autocmd InsertEnter * call plug#load('terminus')
        \| autocmd! Terminus
augroup END

augroup VimCurrentWord
  autocmd!
  autocmd BufReadPost * call plug#load('vim_current_word')
        \| autocmd! VimCurrentWord
augroup END

nnoremap <silent><leader> :<c-u>WhichKey '<space>'<cr>
nnoremap <silent><localleader> :<c-u>WhichKey  '\'<cr>

let g:fzf_layout={'down': '25%'}
nnoremap <leader>ff <cmd>Files<cr>
nnoremap <c-x><c-f> <cmd>Files<cr>
nnoremap <leader>fb <cmd>Buffers<cr>
nnoremap <c-x><c-b> <cmd>Buffers<cr>
nnoremap <leader>fc <cmd>Colors<cr>
nnoremap <leader>fs <cmd>BLines<cr>
nnoremap <leader>fS <cmd>Lines<cr>
nnoremap <c-s> <cmd>BLines<cr>
nnoremap <leader>fr <cmd>History<cr>
nnoremap <c-x><c-r> <cmd>History<cr>
nnoremap <leader><leader> <cmd>Commands<cr>

nnoremap <leader>tu <cmd>UndotreeToggle<cr>

let g:EasyMotion_do_mapping=0
nnoremap <leader>gf <Plug>(easymotion-overwin-f)
nnoremap <leader>gl <Plug>(easymotion-overwin-line)
nnoremap <leader>gw <Plug>(easymotion-overwin-w)

let g:NERDTreeShowHidden=1
nnoremap <leader>tn <cmd>NERDTreeToggle<cr>

let g:floaterm_wintype='split'
let g:floaterm_height=0.3
nnoremap <leader>tt <cmd>FloatermNew<cr>
tnoremap <leader>tt <c-\><c-n><cmd>FloatermKill<cr>
